from typing import Dict, List, Any, Tuple
from google.cloud import bigquery


def split_bq_table_name(table_name: str) -> Tuple[str, str, str]:
    cleaned = table_name.strip().replace("`", "")
    parts = cleaned.split(".")

    if len(parts) != 3:
        raise ValueError(
            f"Expected BigQuery table name as project.dataset.table, got: {table_name}"
        )

    return parts[0], parts[1], parts[2]


def get_bq_columns_metadata(table_name: str) -> Dict[str, Any]:
    project_id, dataset_id, table_id = split_bq_table_name(table_name)

    client = bigquery.Client(project=project_id)

    query = f"""
    SELECT
      table_catalog,
      table_schema,
      table_name,
      column_name,
      ordinal_position,
      is_nullable,
      data_type,
      is_partitioning_column,
      clustering_ordinal_position
    FROM `{project_id}.{dataset_id}.INFORMATION_SCHEMA.COLUMNS`
    WHERE table_name = @table_name
    ORDER BY ordinal_position
    """

    job_config = bigquery.QueryJobConfig(
        query_parameters=[
            bigquery.ScalarQueryParameter("table_name", "STRING", table_id),
        ]
    )

    rows = client.query(query, job_config=job_config).result()

    columns: List[Dict[str, Any]] = []
    for row in rows:
        columns.append(
            {
                "column_name": row["column_name"],
                "ordinal_position": row["ordinal_position"],
                "is_nullable": row["is_nullable"],
                "data_type": row["data_type"],
                "is_partitioning_column": row["is_partitioning_column"],
                "clustering_ordinal_position": row["clustering_ordinal_position"],
            }
        )

    return {
        "table_name": f"{project_id}.{dataset_id}.{table_id}",
        "columns": columns,
    }


def get_bq_table_metadata(table_name: str) -> Dict[str, Any]:
    project_id, dataset_id, table_id = split_bq_table_name(table_name)

    client = bigquery.Client(project=project_id)

    query = f"""
    SELECT
      table_catalog,
      table_schema,
      table_name,
      table_type,
      is_insertable_into,
      is_fine_grained_mutations_enabled,
      is_change_history_enabled
    FROM `{project_id}.{dataset_id}.INFORMATION_SCHEMA.TABLES`
    WHERE table_name = @table_name
    """

    job_config = bigquery.QueryJobConfig(
        query_parameters=[
            bigquery.ScalarQueryParameter("table_name", "STRING", table_id),
        ]
    )

    rows = list(client.query(query, job_config=job_config).result())

    if not rows:
        return {
            "table_name": f"{project_id}.{dataset_id}.{table_id}",
            "table_type": None,
            "is_insertable_into": None,
            "is_fine_grained_mutations_enabled": None,
            "is_change_history_enabled": None,
        }

    row = rows[0]
    return {
        "table_name": f"{project_id}.{dataset_id}.{table_id}",
        "table_type": row["table_type"],
        "is_insertable_into": row["is_insertable_into"],
        "is_fine_grained_mutations_enabled": row["is_fine_grained_mutations_enabled"],
        "is_change_history_enabled": row["is_change_history_enabled"],
    }


def get_bq_full_metadata(table_name: str) -> Dict[str, Any]:
    table_meta = get_bq_table_metadata(table_name)
    column_meta = get_bq_columns_metadata(table_name)

    return {
        "table": table_meta,
        "columns": column_meta["columns"],
    }
